{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dashboard/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "functions": {
      "host": "127.0.0.1",
      "port": 5005
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 8088
    },
    "storage": {
      "host": "127.0.0.1",
      "port": 9199
    },
    "hosting": {
      "host": "127.0.0.1",
      "port": 5006
    },
    "ui": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 4002
    }
  }
}
