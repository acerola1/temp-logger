rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Sensor readings — public read, server-only write
    match /sensorReadings/{document=**} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // Sessions — public read, admin write
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Session types — public read, admin write
    match /sessionTypes/{sessionTypeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Devices — public read, admin write from client
    match /devices/{deviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /sessions/{sessionId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();

        match /events/{eventId} {
          allow read: if true;
          allow create, update, delete: if isAdmin();
        }
      }

      match /readings/{readingId} {
        allow read: if true;
        allow create, update: if false;
        allow delete: if isAdmin();
      }
    }

    // Cuttings — public read, admin write
    match /cuttings/{cuttingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin registry — auth read, server-only write
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
