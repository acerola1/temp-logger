rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /cuttings/{cuttingId}/photos/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
